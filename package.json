{
  "name": "polycoder",
  "version": "0.0.1",
  "private": true,
  "description": "Multi-model AI coding agent for vibe coders. Optimized for MVP-to-production evolution.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "dev": "vite",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently -k -n vite,electron -c blue,green \"pnpm dev\" \"wait-on tcp:5173 && pnpm build:electron && electron dist/electron/main.js\"",
    "electron:build": "pnpm build:electron && pnpm build:renderer",
    "smoke": "tsx scripts/smoke.ts",
    "ist-run": "tsx scripts/ist-run.ts",
    "dist:mac": "pnpm electron:build && electron-builder --mac --publish never",
    "dist:dir": "pnpm electron:build && electron-builder --mac --dir --publish never",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "main": "dist/electron/electron/main.js",
  "build": {
    "appId": "com.chriswu727.polycoder",
    "productName": "polycoder",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/electron/**/*",
      "dist/renderer/**/*",
      "package.json",
      "docs/prompts/**/*"
    ],
    "extraMetadata": {
      "main": "dist/electron/electron/main.js"
    },
    "asarUnpack": [
      "node_modules/keytar/**/*",
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "polycoder ${version}",
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.2.1",
    "electron": "^34.5.8",
    "electron-builder": "^26.8.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^7.0.0",
    "vitest": "^2.1.8",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "keytar": "^7.9.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  }
}

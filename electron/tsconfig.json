{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "../dist/electron",
    "rootDir": "..",
    "noEmit": false,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": [
    "**/*.ts",
    "../core/**/*.ts",
    "../data/**/*.ts",
    "../providers/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "../dist",
    "../src",
    "**/*.test.ts",
    "../core/**/*.test.ts",
    "../data/**/*.test.ts",
    "../providers/**/*.test.ts",
    "../electron/**/*.test.ts"
  ]
}

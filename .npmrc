enable-pre-post-scripts=true
shamefully-hoist=false
strict-peer-dependencies=false

# Resolve optional native bindings (rolldown, better-sqlite3) for all
# platforms developers / CI may run on, so the lockfile is portable.
# Without this, a lockfile generated on macOS misses Linux/Windows
# native bindings → CI fails on the build:renderer step.
supported-architectures.os[]=darwin
supported-architectures.os[]=linux
supported-architectures.os[]=win32
supported-architectures.cpu[]=x64
supported-architectures.cpu[]=arm64
supported-architectures.libc[]=glibc
supported-architectures.libc[]=musl
